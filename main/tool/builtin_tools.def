TOOL_ENTRY("get_diagnostics",
    "Get device health: heap memory (free/min/largest), uptime, rate limits, time sync, timezone, GPIO pins, version.",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_system_diagnostics)

/* Cron - scheduled tasks */
TOOL_ENTRY("cron_schedule",
    "Create a scheduled task. Types: periodic (every N seconds), daily (at specific time), once (after N seconds). Minimum interval: 10 seconds.",
    "{\"type\":\"object\",\"properties\":{"
      "\"type\":{\"type\":\"string\",\"enum\":[\"periodic\",\"daily\",\"once\"],"
        "\"description\":\"Task type: periodic=repeat, daily=at specific time, once=one-time\"},"
      "\"action\":{\"type\":\"string\",\"description\":\"What to do when triggered\"},"
      "\"interval_seconds\":{\"type\":\"integer\",\"minimum\":10,\"description\":\"For periodic: repeat every N seconds (min 10)\"},"
      "\"interval_minutes\":{\"type\":\"integer\",\"description\":\"For periodic: repeat every N minutes (converted to seconds)\"},"
      "\"hour\":{\"type\":\"integer\",\"minimum\":0,\"maximum\":23,\"description\":\"For daily: hour (0-23)\"},"
      "\"minute\":{\"type\":\"integer\",\"minimum\":0,\"maximum\":59,\"description\":\"For daily: minute (0-59)\"},"
      "\"delay_seconds\":{\"type\":\"integer\",\"minimum\":10,\"description\":\"For once: trigger after N seconds (min 10)\"},"
      "\"delay_minutes\":{\"type\":\"integer\",\"description\":\"For once: trigger after N minutes (converted to seconds)\"}},"
    "\"required\":[\"type\",\"action\"]}",
    tool_cron_schedule)

TOOL_ENTRY("cron_list",
    "List all scheduled tasks",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_cron_list)

TOOL_ENTRY("cron_cancel",
    "Cancel a scheduled task by ID",
    "{\"type\":\"object\",\"properties\":{"
      "\"id\":{\"type\":\"integer\",\"description\":\"Task ID to cancel\" } },"
    "\"required\":[\"id\"]}",
    tool_cron_cancel)

TOOL_ENTRY("cron_cancel_all",
    "Cancel ALL scheduled tasks at once",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_cron_cancel_all)

/* Time */
TOOL_ENTRY("get_time",
    "Get current time, timezone, and NTP sync status",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_get_time)

TOOL_ENTRY("set_timezone",
    "Set timezone (e.g., UTC, Asia/Shanghai, America/New_York)",
    "{\"type\":\"object\",\"properties\":{"
      "\"timezone\":{\"type\":\"string\",\"description\":\"Timezone name or POSIX format\"}"
      "},\"required\":[\"timezone\"]}",
    tool_set_timezone)


/* Persona (personality) control */
TOOL_ENTRY("set_persona",
    "Change the AI's personality style. Options: neutral, friendly, technical, witty.",
    "{\"type\":\"object\",\"properties\":{"
      "\"persona\":{\"type\":\"string\",\"description\":\"Persona name: neutral, friendly, technical, or witty\"}"
      "},\"required\":[\"persona\"]}",
    set_persona_exec)

TOOL_ENTRY("get_persona",
    "Get the current AI persona (personality style) setting.",
    "{\"type\":\"object\",\"properties\":{}}",
    get_persona_exec)

/* Network tools */
TOOL_ENTRY("wifi_scan",
    "Scan nearby WiFi networks. Returns SSID, signal strength, channel, and security type. WARNING: This will disconnect from WiFi for 2-5 seconds, so you will lose connection to the LLM temporarily. Always warn the user before calling this tool!",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_wifi_scan)

TOOL_ENTRY("get_network_info",
    "Get current network status: IP address, gateway, netmask, DNS, WiFi signal strength, MAC address, SSID, channel. Use this when user asks about IP, network status, or connection info.",
    "{\"type\":\"object\",\"properties\":{}}",
    tool_get_network_info)

/* ======================= PWM Tools ======================= */
TOOL_ENTRY("pwm_setup",
    "Configure a PWM channel on a GPIO pin for LED dimming or motor speed control. Sets up the hardware PWM generator with specified frequency.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin number\"},"
      "\"channel\":{\"type\":\"integer\",\"description\":\"PWM channel (0-5)\",\"default\":0},"
      "\"freq\":{\"type\":\"integer\",\"description\":\"Frequency in Hz (100-40000, default 5000)\",\"default\":5000}},"
    "\"required\":[\"pin\"]}",
    tool_pwm_setup)

TOOL_ENTRY("pwm_set_duty",
    "Set PWM duty cycle (brightness/speed). 0% = off, 100% = full power.",
    "{\"type\":\"object\",\"properties\":{"
      "\"channel\":{\"type\":\"integer\",\"description\":\"PWM channel (0-5)\",\"default\":0},"
      "\"duty\":{\"type\":\"integer\",\"description\":\"Duty cycle percentage (0-100)\",\"minimum\":0,\"maximum\":100}},"
    "\"required\":[\"duty\"]}",
    tool_pwm_set_duty)

TOOL_ENTRY("pwm_set_freq",
    "Change PWM frequency on an already configured channel.",
    "{\"type\":\"object\",\"properties\":{"
      "\"channel\":{\"type\":\"integer\",\"description\":\"PWM channel (0-5)\",\"default\":0},"
      "\"freq\":{\"type\":\"integer\",\"description\":\"Frequency in Hz (100-40000)\"}},"
    "\"required\":[\"freq\"]}",
    tool_pwm_set_freq)

TOOL_ENTRY("pwm_stop",
    "Stop PWM output on a channel.",
    "{\"type\":\"object\",\"properties\":{"
      "\"channel\":{\"type\":\"integer\",\"description\":\"PWM channel (0-5)\",\"default\":0}},"
    "\"required\":[]}",
    tool_pwm_stop)

TOOL_ENTRY("pwm_status",
    "Get current status of a PWM channel.",
    "{\"type\":\"object\",\"properties\":{"
      "\"channel\":{\"type\":\"integer\",\"description\":\"PWM channel (0-5)\",\"default\":0}},"
    "\"required\":[]}",
    tool_pwm_status)

/* ======================= ADC Tools ======================= */
TOOL_ENTRY("adc_read",
    "Read raw ADC value from a GPIO pin (0-4095 for 12-bit ADC). Use for analog sensors like light sensors, potentiometers.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin with ADC capability\"}},"
    "\"required\":[\"pin\"]}",
    tool_adc_read)

TOOL_ENTRY("adc_read_voltage",
    "Read voltage in millivolts from an ADC pin. Uses calibration for accuracy. Range: 0-3300 mV.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin with ADC capability\"}},"
    "\"required\":[\"pin\"]}",
    tool_adc_read_voltage)

TOOL_ENTRY("adc_read_avg",
    "Read averaged ADC voltage (multiple samples). More stable readings for noisy signals.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin with ADC capability\"},"
      "\"samples\":{\"type\":\"integer\",\"description\":\"Number of samples to average (1-64, default 16)\",\"default\":16}},"
    "\"required\":[\"pin\"]}",
    tool_adc_read_avg)

/* ======================= Servo Tools ======================= */
TOOL_ENTRY("servo_attach",
    "Attach a servo motor to a GPIO pin. Servo starts at center position (0°). Use for robotic arms, curtains, camera gimbals.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin for servo signal\"},"
      "\"id\":{\"type\":\"integer\",\"description\":\"Servo ID (0-3)\",\"default\":0}},"
    "\"required\":[\"pin\"]}",
    tool_servo_attach)

TOOL_ENTRY("servo_write",
    "Move servo to specified angle. Standard servos: -90° to +90°. Continuous rotation servos: angle controls speed.",
    "{\"type\":\"object\",\"properties\":{"
      "\"id\":{\"type\":\"integer\",\"description\":\"Servo ID (0-3)\",\"default\":0},"
      "\"angle\":{\"type\":\"integer\",\"description\":\"Angle in degrees (-90 to +90)\",\"minimum\":-90,\"maximum\":90}},"
    "\"required\":[\"angle\"]}",
    tool_servo_write)

TOOL_ENTRY("servo_write_us",
    "Set servo pulse width directly in microseconds (500-2500). For non-standard servos or precise control.",
    "{\"type\":\"object\",\"properties\":{"
      "\"id\":{\"type\":\"integer\",\"description\":\"Servo ID (0-3)\",\"default\":0},"
      "\"pulse_us\":{\"type\":\"integer\",\"description\":\"Pulse width in microseconds (500-2500)\",\"minimum\":500,\"maximum\":2500}},"
    "\"required\":[\"pulse_us\"]}",
    tool_servo_write_us)

TOOL_ENTRY("servo_read",
    "Get current angle of a servo.",
    "{\"type\":\"object\",\"properties\":{"
      "\"id\":{\"type\":\"integer\",\"description\":\"Servo ID (0-3)\",\"default\":0}},"
    "\"required\":[]}",
    tool_servo_read)

TOOL_ENTRY("servo_detach",
    "Detach servo and release resources. Servo will go limp.",
    "{\"type\":\"object\",\"properties\":{"
      "\"id\":{\"type\":\"integer\",\"description\":\"Servo ID (0-3)\",\"default\":0}},"
    "\"required\":[]}",
    tool_servo_detach)

/* ======================= OneWire Temperature Tools ======================= */
TOOL_ENTRY("temp_setup",
    "Setup a OneWire bus for DS18B20 temperature sensors on a GPIO pin. Requires 4.7K pull-up resistor.",
    "{\"type\":\"object\",\"properties\":{"
      "\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin for OneWire bus\"},"
      "\"bus\":{\"type\":\"integer\",\"description\":\"Bus ID (0-1)\",\"default\":0}},"
    "\"required\":[\"pin\"]}",
    tool_temp_setup)

TOOL_ENTRY("temp_scan",
    "Scan for DS18B20 temperature sensors on a bus. Returns device addresses.",
    "{\"type\":\"object\",\"properties\":{"
      "\"bus\":{\"type\":\"integer\",\"description\":\"Bus ID (0-1)\",\"default\":0}},"
    "\"required\":[]}",
    tool_temp_scan)

TOOL_ENTRY("temp_read",
    "Read temperature from DS18B20 sensor. If no ROM specified, reads from first/only device on bus.",
    "{\"type\":\"object\",\"properties\":{"
      "\"bus\":{\"type\":\"integer\",\"description\":\"Bus ID (0-1)\",\"default\":0},"
      "\"rom\":{\"type\":\"string\",\"description\":\"Device ROM address (16 hex chars, optional)\"}},"
    "\"required\":[]}",
    tool_temp_read)

TOOL_ENTRY("temp_release",
    "Release a OneWire bus and free resources.",
    "{\"type\":\"object\",\"properties\":{"
      "\"bus\":{\"type\":\"integer\",\"description\":\"Bus ID (0-1)\",\"default\":0}},"
    "\"required\":[]}",
    tool_temp_release)
