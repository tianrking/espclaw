# ESPClaw shared defaults (all targets)

# Watchdog - allow long LLM API calls
CONFIG_ESP_TASK_WDT_TIMEOUT_S=60

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# FreeRTOS
CONFIG_FREERTOS_HZ=100

# HTTP client
CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS=y

# TLS certificate bundle
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y

# NVS encryption - disabled for now, enable in Step 8 (production)
# CONFIG_NVS_ENCRYPTION=y

# Partition table (default to 4MB; overridden by sdkconfig.defaults.esp32s3)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_4mb.csv"
