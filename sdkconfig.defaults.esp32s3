# ESPClaw ESP32-S3 specific configuration
# Target: dual-core Xtensa, 512KB SRAM, 4MB flash (标准配置)

# Flash size
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Performance optimization (S3 has room)
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# PSRAM - 禁用 (普通 ESP32-S3 可能没有)
# CONFIG_SPIRAM is not set

# Larger TLS buffers
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=32768
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=16384

# Main task stack
CONFIG_ESP_MAIN_TASK_STACK_SIZE=12288

# Event task stack
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=8192

# Partition table: 4MB (适合普通 ESP32-S3)
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_4mb.csv"

# Enable HTTP server for WebSocket gateway
CONFIG_ESP_HTTPS_SERVER_ENABLE=y
